{
  "name": "tack",
  "version": "0.2.0",
  "private": true,
  "description": "Tack — discipline scaffolding for multi-agent coding (spec-driven development template + tack-bootstrap agent skill)",
  "license": "MIT",
  "bin": {
    "tack": "bin/tack.mjs"
  },
  "files": [
    "bin/tack.mjs",
    "pkg/template"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepack": "rm -rf pkg/template && mkdir -p pkg && cp -R skills/tack-bootstrap/template pkg/template",
    "sync": "bash scripts/sync-skills.sh",
    "check-sync": "bash scripts/check-skills-sync.sh",
    "validate-skill": "bash scripts/validate-skill-frontmatter.sh",
    "validate-skill-evals": "node scripts/validate-skill-evals.mjs",
    "check-routing": "bash scripts/check-routing-snippet.sh",
    "test": "bats test/bats",
    "check-shell": "shellcheck $(git ls-files '*.sh')",
    "check-dispatch": "bash scripts/check-dispatch-contract.sh",
    "install-hooks": "git config core.hooksPath .githooks",
    "lint": "npx -y markdownlint-cli2",
    "check-links": "bash scripts/check-links.sh"
  }
}
